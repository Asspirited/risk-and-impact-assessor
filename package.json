{
  "name": "risk-and-impact-assessor",
  "version": "0.1.0",
  "description": "Agile/BDD project risk and impact assessor with persona commentary",
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "pipeline": "npm test 2>&1"
  },
  "jest": {
    "transform": {},
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "statements": 70,
        "branches": 70
      }
    },
    "coverageReporters": ["text", "lcov"]
  },
  "devDependencies": {
    "jest": "^29.0.0"
  }
}
